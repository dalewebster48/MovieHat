            <viewLayoutGuide key="safeArea" id="vUN-kp-3ea"/>
            <color key="backgroundColor" white="0.0" alpha="0" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
            <constraints>
                <!-- Dimming view: pin to all edges -->
                <constraint firstItem="dim-00-001" firstAttribute="top" secondItem="i5M-Pr-FkT" secondAttribute="top" id="dim-t-001"/>
