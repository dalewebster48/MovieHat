                            <rect key="frame" x="164.5" y="0.0" width="148.5" height="50"/>
                            <color key="backgroundColor" red="1" green="0.62745098039215685" blue="0.039215686274509803" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            <constraints>
